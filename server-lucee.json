{
    "name":"thumbnailator-lucee",
    "app":{
        "cfengine":"lucee@5"
    },
    "web":{
        "host":"0.0.0.0",
        "http":{
            "port":8781
        },
        "rewrites":{
            "enable":false
        },
        "directoryBrowsing":true,
        "blockSensitivePaths":true,
        "webroot":"."
    },
    "jvm":{
        "heapSize":512
    },
    "profile":"development",
    "env":{
        "THUMBNAILATOR_JAR_PATH":"${THUMBNAILATOR_JAR_PATH}",
        "THUMBNAILATOR_JAR_DIR":"${THUMBNAILATOR_JAR_DIR}"
    }
}
