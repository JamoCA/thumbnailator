{
    "name":"thumbnailator-boxlang-lucee",
    "app":{
        "cfengine":"boxlang@1",
        "showErrors":true
    },
    "web":{
        "host":"0.0.0.0",
        "http":{
            "port":8784
        },
        "rewrites":{
            "enable":false
        },
        "directoryBrowsing":true,
        "blockSensitivePaths":true,
        "webroot":"."
    },
    "jvm":{
        "javaHome":"C:\\Program Files\\Java\\jdk-24",
        "args":[
            "-D:javax.xml.accessExternalDTD=''",
            "-D:javax.xml.accessExternalSchema=''",
            "-D:javax.xml.accessExternalStylesheet=''"
        ],
        "javaVersion":"openjdk21"
    },
    "profile":"development",
    "env":{
        "THUMBNAILATOR_JAR_PATH":"${THUMBNAILATOR_JAR_PATH}",
        "THUMBNAILATOR_JAR_DIR":"${THUMBNAILATOR_JAR_DIR}",
        "BOXLANG_COMPAT_MODE":"lucee"
    },
    "scripts":{
        "onServerInitialInstall":"install bx-compat-cfml"
    },
    "debug":true,
    "boxlang":{
        "compatibility":{
            "lucee":true
        },
        "modules":{
            "bx-compat-cfml":{
                "enabled":true,
                "engine":"lucee",
                "clientManagement":false,
                "nullIsUndefined":true,
                "booleansAreNumbers":true,
                "lenientJSONParsing":false,
                "queryNullToEmpty":true
            }
        }
    }
}
