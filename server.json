{
    "name": "thumbnailator-adobe",
    "app": { "cfengine": "adobe@2016" },
    "web": {
        "host": "0.0.0.0",
        "http": { "port": 8780 },
        "rewrites": { "enable": true, "config": "urlrewrite.xml" },
        "directoryBrowsing": true,
        "blockSensitivePaths": true,
        "webroot": "."
    },
    "jvm": { "heapSize": 512 },
    "profile": "development",
    "env": {
        "THUMBNAILATOR_JAR_PATH": "${THUMBNAILATOR_JAR_PATH}",
        "THUMBNAILATOR_JAR_DIR": "${THUMBNAILATOR_JAR_DIR}"
    }
}
