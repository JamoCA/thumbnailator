{
    "name":"thumbnailator-boxlang",
    "app":{
        "cfengine":"boxlang@1",
        "showErrors":true
    },
    "web":{
        "host":"0.0.0.0",
        "http":{
            "port":8782
        },
        "rewrites":{
            "enable":false
        },
        "directoryBrowsing":true,
        "blockSensitivePaths":true,
        "webroot":"."
    },
    "jvm":{
        "args":[
            "-D:javax.xml.accessExternalDTD=''",
            "-D:javax.xml.accessExternalSchema=''",
            "-D:javax.xml.accessExternalStylesheet=''"
        ],
        "javaVersion":"openjdk21"
    },
    "profile":"development",
    "env":{
        "THUMBNAILATOR_JAR_PATH":"${THUMBNAILATOR_JAR_PATH}",
        "THUMBNAILATOR_JAR_DIR":"${THUMBNAILATOR_JAR_DIR}",
        "BOXLANG_COMPAT_MODE":""
    },
    "debug":true
}
