{
    "name": "thumbnailator",
    "version": "0.4.21+7",
    "author": "James Moberg <james@sunstarmedia.com>",
    "location": "",
    "slug": "thumbnailator",
    "shortDescription": "CFML wrapper for the Thumbnailator Java thumbnail library",
    "type": "modules",
    "homepage": "https://github.com/JamoCA/thumbnailator",
    "documentation": "https://github.com/JamoCA/thumbnailator#readme",
    "repository": {
        "type": "git",
        "URL": "https://github.com/JamoCA/thumbnailator"
    },
    "bugs": "https://github.com/JamoCA/thumbnailator/issues",
    "keywords": ["thumbnail", "image", "resize", "crop", "watermark", "rotate", "thumbnailator", "java"],
    "engines": [
        { "type": "adobe", "version": ">=2016.0.0" },
        { "type": "lucee", "version": ">=5.0.0" },
        { "type": "boxlang", "version": ">=1.0.0" }
    ],
    "dependencies": {
        "thumbnailator-jar": "jar:https://repo1.maven.org/maven2/net/coobird/thumbnailator/0.4.21/thumbnailator-0.4.21.jar"
    },
    "installPaths": {
        "thumbnailator-jar": "lib/thumbnailator/"
    },
    "ignore": [
        "lib/",
        ".git*",
        ".env",
        ".cfformat.json",
        ".engine/",
        ".bx-server/",
        ".boxr/",
        ".idea/",
        ".vscode/",
        ".DS_Store",
        "Thumbs.db",
        "tests/",
        "demo*.cfm",
        "demo-images/",
        "demo-output/",
        "server*.json",
        "docs/"
    ]
